{
  "expo": {
    "name": "Refind",
    "slug": "refind",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "refind",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "com.apple.developer.kernel.extended-virtual-addressing": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tanay22.refind",
      "permissions": [
        "ACCESS_MEDIA_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "withSQLiteVecExtension": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Refind to access your screenshots.",
          "savePhotosPermission": "Allow Refind to save screenshots.",
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-background-task",
      [
        "rn-mlkit-ocr",
        {
          "ocrModels": [
            "latin",
            "devanagari"
          ],
          "ocrUseBundled": true
        }
      ],
      "react-native-notify-kit",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b3a9ae42-d9cd-463f-a47e-fc6bb758e11b"
      }
    },
    "owner": "tanay22"
  }
}
